{
  "name": "patchwave-analysis",
  "version": "0.0.1",
  "description": "Diagnostic CLI that measures Dependabot toil and CVE exposure across a GitHub org.",
  "type": "module",
  "bin": {
    "patchwave-analysis": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0 --cache",
    "lint:fix": "eslint . --fix --cache",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "prepare": "husky",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 ./src/index.ts --outfile dist/patchwave-analysis-darwin-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 ./src/index.ts --outfile dist/patchwave-analysis-darwin-x64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 ./src/index.ts --outfile dist/patchwave-analysis-linux-x64"
  },
  "prettier": "@contextbridge-ai/prettier-config",
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix --no-warn-ignored",
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@contextbridge-ai/eslint-config": "^0.0.0",
    "@contextbridge-ai/prettier-config": "^0.0.0",
    "@types/bun": "latest",
    "@types/semver": "^7.7.1",
    "eslint": "^10.4.0",
    "fishery": "^2.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "neverthrow": "^8.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "posthog-node": "^5.35.1",
    "semver": "^7.8.1",
    "zod": "^4.4.3"
  }
}
